datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE_PERIOD
  LOCKED
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum Status {
  ACTIVE
  INACTIVE
}

enum OrderSource {
  CUSTOMER_APP
  STAFF_MANUAL
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum PaymentMethod {
  CASH
  MOMO
  CARD
  PAYSTACK
}

enum InventoryChangeReason {
  RESTOCK
  USAGE
  ADJUSTMENT
}

enum ReconciliationStatus {
  PENDING_REVIEW
  RECONCILED
  DISCREPANCY_FLAGGED
}

model Restaurant {
  id                  String             @id @default(uuid()) @db.Uuid
  name                String
  logoUrl             String?
  address             String
  contactPhone        String
  contactEmail        String
  paystackPublicKey   String?
  momoMerchantId      String?
  subscriptionStatus  SubscriptionStatus @default(TRIAL)
  trialEndsAt         DateTime?
  currentPeriodEndsAt DateTime?
  gracePeriodEndsAt   DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  users               User[]
  tables              Table[]
  menuCategories      MenuCategory[]
  menuItems           MenuItem[]
  orders              Order[]
  inventoryItems      InventoryItem[]
  feedbacks           Feedback[]
  auditLogs           AuditLog[]
  subscriptionPayments SubscriptionPayment[]
  reconciliations     DailyReconciliation[]
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @db.Uuid
  name         String
  email        String     @unique
  phone        String
  passwordHash String
  role         Role
  status       Status
  failedLoginAttempts Int @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
}

model Table {
  id           String       @id @default(uuid()) @db.Uuid
  restaurantId String       @db.Uuid
  tableNumber  String
  capacity     Int?
  qrCodeUrl    String
  createdAt    DateTime     @default(now())

  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id])
  tokens       TableToken[]
  orders       Order[]
  feedbacks    Feedback[]

  @@index([restaurantId])
}

model TableToken {
  id        String   @id @default(uuid()) @db.Uuid
  tableId   String   @db.Uuid
  token     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  table     Table    @relation(fields: [tableId], references: [id])

  @@index([token])
}

model MenuCategory {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @db.Uuid
  name         String
  displayOrder Int
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id             String     @id @default(uuid()) @db.Uuid
  restaurantId   String     @db.Uuid
  categoryId     String     @db.Uuid
  name           String
  description    String
  price          Decimal    @db.Decimal(10, 2)
  imageUrl       String
  available      Boolean    @default(true)
  popular        Boolean    @default(false)
  prepTime       Int        // in minutes
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])
  category       MenuCategory @relation(fields: [categoryId], references: [id])
  variants       MenuItemVariant[]
  addOns         MenuItemAddOn[]
  orderItems     OrderItem[]
  inventoryLinks MenuItemInventoryLink[]
  ratings        FeedbackItemRating[]

  @@index([restaurantId])
  @@index([restaurantId, available])
}

model MenuItemVariant {
  id            String      @id @default(uuid()) @db.Uuid
  menuItemId    String      @db.Uuid
  name          String
  priceModifier Decimal     @default(0) @db.Decimal(10, 2)

  menuItem      MenuItem    @relation(fields: [menuItemId], references: [id])
  orderItems    OrderItem[]
}

model MenuItemAddOn {
  id            String             @id @default(uuid()) @db.Uuid
  menuItemId    String             @db.Uuid
  name          String
  price         Decimal            @db.Decimal(10, 2)

  menuItem      MenuItem           @relation(fields: [menuItemId], references: [id])
  orderItems    OrderItemAddOn[]
}

model Order {
  id                String         @id @default(uuid()) @db.Uuid
  restaurantId      String         @db.Uuid
  tableId           String         @db.Uuid
  status            OrderStatus
  paymentStatus     PaymentStatus
  paymentMethod     PaymentMethod
  total             Decimal        @db.Decimal(10, 2)
  customerName      String?
  notes             String?
  source            OrderSource    @default(CUSTOMER_APP)
  paystackReference String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  restaurant        Restaurant     @relation(fields: [restaurantId], references: [id])
  table             Table          @relation(fields: [tableId], references: [id])
  items             OrderItem[]
  feedbacks         Feedback[]

  @@index([restaurantId, status])
  @@index([tableId])
}

model OrderItem {
  id                String             @id @default(uuid()) @db.Uuid
  orderId           String             @db.Uuid
  menuItemId        String             @db.Uuid
  quantity          Int
  price             Decimal            @db.Decimal(10, 2)
  notes             String?
  selectedVariantId String?            @db.Uuid

  order             Order              @relation(fields: [orderId], references: [id])
  menuItem          MenuItem           @relation(fields: [menuItemId], references: [id])
  selectedVariant   MenuItemVariant?   @relation(fields: [selectedVariantId], references: [id])
  selectedAddOns    OrderItemAddOn[]
}

model OrderItemAddOn {
  orderItemId     String          @db.Uuid
  addOnId         String          @db.Uuid

  orderItem       OrderItem       @relation(fields: [orderItemId], references: [id])
  addOn           MenuItemAddOn   @relation(fields: [addOnId], references: [id])

  @@id([orderItemId, addOnId])
}

model InventoryItem {
  id                String     @id @default(uuid()) @db.Uuid
  restaurantId      String     @db.Uuid
  name              String
  unit              String
  currentStock      Decimal    @db.Decimal(10, 2)
  lowStockThreshold Decimal    @db.Decimal(10, 2)
  supplier          String?
  lastRestockedAt   DateTime?

  restaurant        Restaurant @relation(fields: [restaurantId], references: [id])
  logs              InventoryLog[]
  menuItemLinks     MenuItemInventoryLink[]

  @@index([restaurantId])
}

model InventoryLog {
  id               String                 @id @default(uuid()) @db.Uuid
  inventoryItemId  String                 @db.Uuid
  userId           String                 @db.Uuid
  changeAmount     Decimal                @db.Decimal(10, 2)
  reason           InventoryChangeReason
  createdAt        DateTime               @default(now())

  inventoryItem    InventoryItem          @relation(fields: [inventoryItemId], references: [id])
}

model MenuItemInventoryLink {
  id                  String         @id @default(uuid()) @db.Uuid
  menuItemId          String         @db.Uuid
  inventoryItemId     String         @db.Uuid
  quantityUsedPerOrder Decimal       @db.Decimal(10, 2)

  menuItem            MenuItem       @relation(fields: [menuItemId], references: [id])
  inventoryItem       InventoryItem  @relation(fields: [inventoryItemId], references: [id])
}

model Feedback {
  id            String     @id @default(uuid()) @db.Uuid
  orderId       String     @db.Uuid
  tableId       String     @db.Uuid
  restaurantId  String     @db.Uuid
  overallRating Int
  comment       String?
  isReviewed    Boolean    @default(false)
  createdAt     DateTime   @default(now())

  order         Order      @relation(fields: [orderId], references: [id])
  table         Table      @relation(fields: [tableId], references: [id])
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  itemRatings   FeedbackItemRating[]

  @@index([restaurantId])
}

model FeedbackItemRating {
  id          String   @id @default(uuid()) @db.Uuid
  feedbackId  String   @db.Uuid
  menuItemId  String   @db.Uuid
  thumbsUp    Boolean

  feedback    Feedback @relation(fields: [feedbackId], references: [id])
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])
}

model AuditLog {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @db.Uuid
  userId       String     @db.Uuid
  action       String
  entityType   String
  entityId     String
  createdAt    DateTime   @default(now())

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([restaurantId, createdAt])
}

model SubscriptionPayment {
  id                String     @id @default(uuid()) @db.Uuid
  restaurantId      String     @db.Uuid
  amount            Decimal    @db.Decimal(10, 2)
  status            String     // 'PENDING' | 'SUCCESS' | 'FAILED'
  paystackReference String     @unique
  createdAt         DateTime   @default(now())

  restaurant        Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

model DailyReconciliation {
  id                     String               @id @default(uuid()) @db.Uuid
  restaurantId           String               @db.Uuid
  date                   DateTime             @db.Date
  totalOrdersCount       Int
  totalRevenue           Decimal              @db.Decimal(10, 2)
  revenueByPaymentMethod Json                 // { cash, momo, card, paystack }
  expectedInventoryUsage Json                 // [{ inventoryItemId, expectedDeduction }]
  actualInventoryLogged  Json                 // [{ inventoryItemId, actualDeduction }]
  discrepancies          Json                 // [{ inventoryItemId, expected, actual, variance }]
  physicalCountSubmitted Boolean              @default(false)
  physicalCounts         Json?                // Optional: { inventoryItemId: countedQuantity }
  status                 ReconciliationStatus
  createdAt              DateTime             @default(now())

  restaurant             Restaurant           @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, date])
  @@index([restaurantId])
}
